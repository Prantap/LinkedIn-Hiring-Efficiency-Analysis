 / Non-profit\": [\n","        \"government\", \"public sector\", \"nonprofit\", \"non-profit\", \"ngo\", \"grant\",\n","        \"community outreach\", \"public policy\"\n","    ]\n","}\n"],"metadata":{"id":"1WCKhadXZWfF"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Function to infer primary industry from description keywords\n","def infer_industry(desc_clean: str) -> str:\n","    \"\"\"\n","    Count keyword hits for each industry and return the one with the highest score.\n","    If no keywords are found, return 'Other / Mixed'.\n","    \"\"\"\n","    if not desc_clean:\n","        return \"Other / Mixed\"\n","\n","    scores = {ind: 0 for ind in industry_keywords}\n","\n","    for industry, keywords in industry_keywords.items():\n","        for kw in keywords:\n","            if kw in desc_clean:\n","                scores[industry] += 1\n","\n","    # Find highest scoring industry\n","    best_industry = max(scores, key=scores.get)\n","    if scores[best_industry] == 0:\n","        return \"Other / Mixed\"\n","    return best_industry\n","\n","data[\"industry_bucket\"] = data[\"description_clean\"].apply(infer_industry)\n","print(\"Inferred Industry Distribution:\")\n","print(data[\"industry_bucket\"].value_counts(dropna=False))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"yYtRt4oAZsWf","executionInfo":{"status":"ok","timestamp":1764436149532,"user_tz":-330,"elapsed":59557,"user":{"displayName":"Pran S","userId":"15779970413069318186"}},"outputId":"6465fe8a-0e94-4857-b93d-efddd42e2606"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Inferred Industry Distribution:\n","industry_bucket\n","Technology / IT               36060\n","Healthcare                    30725\n","Finance / Banking             15814\n","Retail / E-commerce           11726\n","Education / Training           9124\n","Manufacturing / Operations     8996\n","Marketing / Advertising        4433\n